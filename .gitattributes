# Ensure consistent line endings
* text=auto

# Force LF for source files to match rustfmt / prettier output on all platforms
*.rs text eol=lf
*.toml text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.svg text eol=lf

# Binary files — no line ending conversion
*.ico binary
*.png binary
*.icns binary
*.woff2 binary
*.woff binary
*.ttf binary
*.eot binary
