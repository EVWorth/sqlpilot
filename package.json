    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "clsx": "^2.1.0",
    "lucide-react": "^1.16.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4.11.2",
    "sql-formatter": "^15.8.0",
    "tailwind-merge": "^3.6.0",
